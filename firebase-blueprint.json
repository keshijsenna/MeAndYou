{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "Chat messages between the couple.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "voiceBase64": { "type": "string", "description": "Optional base64 encoded voice data or tiny thumbnail" },
        "voiceUrl": { "type": "string", "description": "Link to voice note in Firebase Storage" },
        "voiceDuration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "text", "createdAt"]
    },
    "Mood": {
      "title": "Mood",
      "description": "Daily mood logs for the couple.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "dateStr": { "type": "string", "description": "YYYY-MM-DD string" },
        "displayDate": { "type": "string" },
        "time": { "type": "string" },
        "mood": { "type": "string", "description": "Emoji" },
        "label": { "type": "string" },
        "color": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "dateStr", "mood", "createdAt"]
    },
    "Dream": {
      "title": "Dream",
      "description": "Shared dreams and bucket list items.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "done": { "type": "boolean" },
        "color": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "done"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Planned dates or events.",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "title"]
    },
    "LoveLetter": {
      "title": "Love Letter",
      "description": "Drafts of love letters.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "userId"]
    },
    "Photo": {
      "title": "Photo",
      "description": "Shared photos in the gallery.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url"]
    },
    "Memory": {
      "title": "Memory",
      "description": "Timeline memories.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "likes": { "type": "number" },
        "img": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["title", "date"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages."
    },
    "/moods/{moodId}": {
      "schema": "Mood",
      "description": "Daily mood entries."
    },
    "/dreams/{dreamId}": {
      "schema": "Dream",
      "description": "Couple bucket list."
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Calendar events."
    },
    "/love_letters/{userId}": {
      "schema": "LoveLetter",
      "description": "One draft per user."
    },
    "/photos/{photoId}": {
      "schema": "Photo",
      "description": "Gallery images."
    },
    "/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Shared timeline entries."
    },
    "/settings/appLock": {
      "schema": {
        "type": "object",
        "properties": {
          "pinHash": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "App-level settings."
    }
  }
}
