rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /photos/{document=**} {
      allow read, write: if true;
    }
    match /schedules/{document=**} {
      allow read, write: if true;
    }
    match /dreams/{document=**} {
      allow read, write: if true;
    }
    match /memories/{document=**} {
      allow read, write: if true;
    }
    match /settings/{document=**} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
